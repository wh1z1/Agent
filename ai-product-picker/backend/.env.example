# AI 选品官 — 环境配置
# 实际部署时替换为真实 API Key

# 大模型 API（用于内容生成）
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# 1688 供应链 API
SUPPLIER_API_KEY=your_1688_key

# 电商平台 API
TAOBAO_APP_KEY=your_taobao_key
PINDUODUO_APP_KEY=your_pdd_key
DOUYIN_APP_KEY=your_douyin_key

# 数据库（可选）
DATABASE_URL=sqlite:///./data.db
